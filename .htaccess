<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Rotear requisições de API para api.php
  RewriteRule ^api/(.*)$ api.php?path=/$1 [QSA,L]

  # Garantir que arquivos e diretórios existentes sejam servidos normalmente
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
</IfModule>
